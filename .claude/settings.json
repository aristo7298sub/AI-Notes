{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:4399",
    "API_TIMEOUT_MS": "3000000",
    "ANTHROPIC_MODEL": "claude-opus-4.6",
    "ANTHROPIC_AUTH_TOKEN": "dummy",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4.6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4.6-1m[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4.5",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-opus-4.6-1m[1m]",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "high"
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(pm2 *)",
      "Bash(python *)",
      "Bash(pip install*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git pull*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git stash*)",
      "Bash(az *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(echo *)",
      "Bash(Get-Content *)",
      "Bash(Get-ChildItem *)",
      "Bash(Write-Host *)",
      "Bash(Select-String *)",
      "Bash(Start-Sleep *)",
      "Bash(Stop-Process *)",
      "Bash(node scripts/*.js)"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  }
}