  "escalation": {
    "description": "升级工具 — 文档生成 + IcM 事件操作",
    "tools": {
      "Read": {
        "enabled": true
      },
      "Write": {
        "enabled": true
      },
      "Edit": {
        "enabled": true
      },
      "Bash": {
        "enabled": true
      },
      "Glob": {
        "enabled": true
      },
      "Grep": {
