{
  // Aristo-Avatar Toolsets Configuration
  // 定义不同 agent 角色的工具权限和 MCP 服务器访问范围
  // 参考: https://docs.anthropic.com/en/docs/claude-code/toolsets
  // === 默认工具集 ===
  // 所有 agent 和 session 都可用的基础工具
  "default": {
    "description": "基础工具 — 文件读写、终端、搜索",
    "tools": {
      "Read": {
        "enabled": true
      },
      "Write": {
        "enabled": true
      },
      "Edit": {
        "enabled": true
      },
      "Bash": {
        "enabled": true
      },
      "Glob": {
        "enabled": true
      },
      "Grep": {
        "enabled": true
      },
      "LS": {
        "enabled": true
      }
    }
  },
  // === 调查工具集 ===
  // 用于 Kusto 调查的 agent (platform/apim/backend-investigator)
  "investigation": {
    "description": "调查工具 — Kusto 查询 + 文件操作",
    "tools": {
      "Read": {
        "enabled": true
      },
      "Write": {
        "enabled": true
      },
      "Edit": {
        "enabled": true
      },
      "Bash": {
        "enabled": true
      },
      "Glob": {
        "enabled": true
      },
      "Grep": {
        "enabled": true
      },
      "LS": {
        "enabled": true
      },
      "Task": {
        "enabled": true
      }
    },
    "mcpServers": {
      "azure-kusto": {
        "enabled": true
      },
      "microsoft-docs": {
        "enabled": true
      }
    }
  },
  // === IcM 工具集 ===
  // 用于 icm-scanner agent
  "icm": {
    "description": "IcM 事件搜索工具",
    "tools": {
      "Read": {
        "enabled": true
      },
      "Grep": {
        "enabled": true
      },
      "LS": {
        "enabled": true
      }
    },
    "mcpServers": {
      "icm-mcp": {
        "enabled": true
      }
    }
  },
  // === ASC 工具集 ===
  // 用于 asc-diagnostics agent
  "asc": {
    "description": "ASC 资源诊断工具",
    "tools": {
      "Read": {
        "enabled": true
      },
      "Grep": {
        "enabled": true
      },
      "LS": {
        "enabled": true
      },
      "Bash": {
        "enabled": true
      }
    },
    "mcpServers": {
      "asc": {
        "enabled": true
      }
    }
  },
  // === CRM 工具集 ===
  // 用于 CRM 案例查询
  "crm": {
    "description": "CRM 案例搜索工具",
    "tools": {
      "Read": {
        "enabled": true
      },
      "Grep": {
        "enabled": true
      }
    },
    "mcpServers": {
      "crm": {
        "enabled": true
      }
    }
  },
  // === M365 工具集 ===
  // 用于 Work IQ 搜索
  "m365": {
    "description": "M365 上下文搜索工具 (邮件、Teams、会议、文件)",
    "tools": {
      "Read": {
        "enabled": true
      },
      "Grep": {
        "enabled": true
      }
    },
    "mcpServers": {
      "workiq": {
        "enabled": true
      }
    }
  },
  // === 行动工具集 ===
  // 用于 reproducer, communicator agent
  "action": {
    "description": "行动工具 — 代码生成、文件写入、终端执行",
    "tools": {
      "Read": {
        "enabled": true
      },
      "Write": {
        "enabled": true
      },
      "Edit": {
        "enabled": true
      },
      "Bash": {
